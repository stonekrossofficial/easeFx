name: easefx_ai
description: "A lightweight AI-powered photo editing app providing high-quality filters, face enhancements, and creative effects."
publish_to: 'none'

version: 1.0.0+1

environment:
  sdk: '>=3.3.0 <4.0.0'

dependencies:
  flutter:
    sdk: flutter
  flutter_bloc: ^8.1.5
  equatable: ^2.0.5
  go_router: ^13.2.0
  google_fonts: ^6.2.1
  image_picker: ^1.1.1
  http: ^1.2.1
  transparent_image: ^2.0.1
  #path_provider: ^2.1.2
  crypto: ^3.0.3
  pointycastle: ^3.7.3
  uuid: ^4.4.0
  path: ^1.9.0
  #share_plus: ^9.0.0
  #gal: ^1.2.2
  shared_preferences: ^2.3.1
  flutter_launcher_icons: ^0.14.4
  shimmer: ^3.0.0
  cached_network_image: ^3.4.0
  get_it: ^9.2.1
  injectable: ^3.0.0
  dio: ^5.9.2
  connectivity_plus: ^7.1.1
  fpdart: ^1.2.0
  freezed_annotation: ^3.1.0
  json_annotation: ^4.11.0
  flutter_animate: ^4.5.2
  logger: ^2.7.0
  flutter_secure_storage: ^10.0.0


dev_dependencies:
  flutter_test:
    sdk: flutter
  flutter_lints: ^3.0.0
  build_runner: ^2.14.0
  freezed: ^3.2.5
  json_serializable: ^6.13.1
  injectable_generator: ^3.0.2
flutter_launcher_icons:
  android: true
  ios: true
  web:
    generate: true
    image_path: "asset/playstore.png"
    background_color: "#FFFFFF"
    theme_color: "#FFFFFF"
  image_path: "asset/playstore.png"
  adaptive_icon_background: "#FFFFFF"
  adaptive_icon_foreground: "asset/playstore.png"

flutter:
  uses-material-design: true
